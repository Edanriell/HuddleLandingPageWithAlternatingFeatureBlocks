{
	"name": "client",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"start:dev": "vite dev",
		"start:build": "vite build",
		"start:preview": "vite preview",
		"start:prepare": "svelte-kit sync || echo ''",
		"start:check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"start:check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"start:format": "prettier --write .",
		"start:lint": "prettier --check . && eslint .",
		"start:test:unit": "vitest",
		"start:test": "npm run test:unit -- --run",
		"start:storybook": "storybook dev -p 6006",
		"start:build-storybook": "storybook build"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^4.0.0",
		"@eslint/compat": "^1.3.0",
		"@eslint/js": "^9.29.0",
		"@fontsource/fira-mono": "^5.2.6",
		"@neoconfetti/svelte": "^2.2.2",
		"@storybook/addon-a11y": "^9.0.10",
		"@storybook/addon-docs": "^9.0.10",
		"@storybook/addon-svelte-csf": "^5.0.3",
		"@storybook/addon-vitest": "^9.0.10",
		"@storybook/sveltekit": "^9.0.10",
		"@sveltejs/adapter-auto": "^6.0.1",
		"@sveltejs/kit": "^2.21.5",
		"@sveltejs/vite-plugin-svelte": "^5.1.0",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/typography": "^0.5.16",
		"@tailwindcss/vite": "^4.1.10",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/svelte": "^5.2.8",
		"@types/node": "^22.15.31",
		"eslint": "^9.29.0",
		"eslint-config-prettier": "^10.1.5",
		"eslint-plugin-storybook": "^9.0.10",
		"eslint-plugin-svelte": "^3.9.2",
		"globals": "^16.2.0",
		"jsdom": "^26.1.0",
		"prettier": "^3.5.3",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.6.12",
		"storybook": "^9.0.10",
		"svelte": "^5.34.3",
		"svelte-check": "^4.2.1",
		"tailwindcss": "^4.1.10",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.34.0",
		"vite": "^6.3.5",
		"vitest": "^3.2.3"
	},
	"dependencies": {
		"less": "^4.3.0",
		"sanitize.css": "^13.0.0"
	}
}
